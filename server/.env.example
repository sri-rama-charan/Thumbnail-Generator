# =========================================================================
# Purpose: Configuration template for server environment variables.
# This file serves as a blueprint for the local development environment (.env).
# Duplicate this file to '.env' and fill in the actual keys/passwords.
# =========================================================================

# The port on which the Express server will listen locally
PORT=5000

# The MongoDB Atlas connection string for user and thumbnail persistence
MONGO_URI=mongodb+srv://dbUser:<db_password>@cluster0.fweuxm9.mongodb.net/?appName=Cluster0

# A strong secret key used by jsonwebtoken to sign and verify JWT authorization tokens
JWT_SECRET=replace_with_a_strong_secret

# The backend port or URL of the client application (used to configure CORS)
CLIENT_URL=http://localhost:5173

# Optional: Groq credentials for AI prompt refinement (needed for Phase 2+)
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
